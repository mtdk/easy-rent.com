# OS files
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.fleet/
*.swp
*.swo
*~

# PHP dependencies
/vendor/

# Composer artifacts
composer.phar

# Environment and secrets
.env
.env.*
!.env.example

# Runtime storage (logs, cache, sessions, temp, backups)
/storage/logs/*
!/storage/logs/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/framework/*
!/storage/framework/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
/storage/import-preview/*
!/storage/import-preview/.gitkeep
/storage/app/*
!/storage/app/.gitkeep
/storage/database/*
!/storage/database/.gitkeep

# Database local files
*.sqlite
*.sqlite3

# Test and coverage artifacts
coverage/
.phpunit.result.cache
.phpunit.cache/

# PHP tooling cache
.php-cs-fixer.cache
.phpactor.json

# Build and temporary files
*.log
*.tmp
*.temp
*.bak
*.orig
.cache/
.tmp/

# JS package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node artifacts (if frontend tooling is used)
node_modules/
dist/
build/
