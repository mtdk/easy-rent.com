{
    "name": "easy-rent/rent-management-system",
    "description": "收租管理系统 - 基于PHP8+MariaDB+Bootstrap的局域网租赁管理平台",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Easy Rent Team",
            "email": "team@easy-rent.local"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php database/migrate.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}